# Copy this file to .env and fill in the values.
# Never commit your actual .env to Git.

# Node environment
NODE_ENV=development

# JWT secret for authentication
JWT_SECRET=change_me_in_production

# Database configuration
# For local development, use SQLite (DB_PATH)
# For production on Render, use PostgreSQL (DATABASE_URL)
DB_PATH=./eccp.db
# DATABASE_URL=postgres://user:password@host:port/database

# Allowed origin for CORS (set to your Render domain in production)
ALLOWED_ORIGIN=https://your-render-app.onrender.com

# SMTP settings for email (optional)
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-email
SMTP_PASS=your-password

# Server port
PORT=10000
API_PORT=10000