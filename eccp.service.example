[Unit]
Description=ECCP 2026 Platform
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/eccp
Environment=NODE_ENV=production
# Load environment variables from file (if using)
EnvironmentFile=/opt/eccp/.env
ExecStart=/usr/local/bin/node server/index.js
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target